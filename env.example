NEXT_PUBLIC_APP_NAME="Etherium Antennas"

NODE_ENV="production"
NEXT_TELEMETRY_DISABLED="1"
HOST="0.0.0.0"
PORT="3000"
HOST_PORT="3200"
APP_URL="http://localhost:3200"
COOKIE_SECURE="true"
FORCE_HTTP="false"
ALLOW_SELF_REGISTER="false"

APP_IMAGE="monitoring_grandstream:latest"

MYSQL_IMAGE="mysql:8.4"
MYSQL_HOST="mysql"
MYSQL_PORT="3307"
MYSQL_HOST_PORT="3307"
MYSQL_DATABASE="monitoring_grandstream"
MYSQL_USER="monitoring_app"
MYSQL_PASSWORD="change-me-app-password"
MYSQL_ROOT_PASSWORD="change-me-root-password"
MYSQL_CHARSET="utf8mb4"
MYSQL_COLLATION="utf8mb4_unicode_ci"

DATABASE_URL="mysql://monitoring_app:change-me-app-password@mysql:3307/monitoring_grandstream"

JWT_SECRET="change-me-jwt-secret"
JWT_EXPIRES_DAYS="7"
INTERNAL_API_KEY="change-me-internal-api-key"
PASSWORD_RESET_BASE_URL=""
PASSWORD_RESET_TOKEN_MINUTES="60"
EMAIL_DEFAULT_FROM="noreply@example.com"
EMAIL_TRANSPORT_DEFAULT_HOST="smtp.example.com"
EMAIL_TRANSPORT_DEFAULT_PORT="587"
EMAIL_TRANSPORT_DEFAULT_USERNAME=""
EMAIL_TRANSPORT_DEFAULT_PASSWORD=""
EMAIL_TRANSPORT_DEFAULT_TLS="true"
PASSBOLT_KEY_EMAIL="noreply@example.com"

GDMS_BASE="https://www.gwn.cloud"
GDMS_OAUTH_URL="https://www.gwn.cloud/oauth/token"
GDMS_CLIENT_ID=""
GDMS_CLIENT_SECRET=""
GDMS_PAGE_SIZE="500"
GDMS_SHOW="all"
GDMS_SYNC_INTERVAL_MS="300000"

SUPERADMIN_EMAIL="admin@example.com"
SUPERADMIN_PASSWORD="change-me-superadmin-password"
SUPERADMIN_NAME="Root"

APP_BASE_URL="http://web:3000"
SYNC_PATH="/api/integrations/gdms/sync?mode=status"
SYNC_INTERVAL_MS="300000"
