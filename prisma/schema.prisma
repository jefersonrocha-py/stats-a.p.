generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Antenna {
  id               Int             @id @default(autoincrement())
  name             String
  description      String?
  lat              Float           @default(0)
  lon              Float           @default(0)
  status           String          @default("DOWN")
  gdmsApId         String?         @unique
  networkId        String?
  networkName      String?
  lastSyncAt       DateTime?
  lastStatusChange DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  statusHistory    StatusHistory[]

  @@index([status])
  @@index([lat, lon])
  @@index([gdmsApId])
  @@index([networkId])
}

model StatusHistory {
  id        Int      @id @default(autoincrement())
  antennaId Int
  status    String
  changedAt DateTime @default(now())
  antenna   Antenna  @relation(fields: [antennaId], references: [id], onDelete: Cascade)

  @@index([antennaId, changedAt])
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("USER")
  isBlocked    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([role])
}

model GdmsToken {
  id          Int      @id
  accessToken String   @db.Text
  expiresAt   DateTime
  updatedAt   DateTime @updatedAt

  @@map("gdms_token")
}
